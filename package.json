{
  "name": "qa-management-app",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "DATABASE_URL=$(tsx scripts/resolve-database-url.ts) next dev",
    "build": "DATABASE_URL=$(tsx scripts/resolve-database-url.ts) next build",
    "start": "DATABASE_URL=$(tsx scripts/resolve-database-url.ts) next start",
    "lint": "eslint",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "db:generate": "DATABASE_URL=$(tsx scripts/resolve-database-url.ts) drizzle-kit generate",
    "db:migrate": "DATABASE_URL=$(tsx scripts/resolve-database-url.ts) drizzle-kit migrate",
    "db:push": "DATABASE_URL=$(tsx scripts/resolve-database-url.ts) drizzle-kit push",
    "db:studio": "DATABASE_URL=$(tsx scripts/resolve-database-url.ts) drizzle-kit studio --host 127.0.0.1 --port 4983",
    "db:studio:stop": "lsof -tiTCP:4983 -sTCP:LISTEN | xargs -r kill",
    "db:seed": "DATABASE_URL=$(tsx scripts/resolve-database-url.ts) tsx src/db/seed.ts",
    "db:resolve": "tsx scripts/resolve-database-url.ts",
    "db:reset:home": "DATABASE_URL=$(tsx scripts/resolve-database-url.ts) tsx scripts/reset-database.ts"
  },
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dotenv": "^17.4.2",
    "drizzle-orm": "^0.45.2",
    "lucide-react": "^1.16.0",
    "next": "16.2.6",
    "pg": "^8.21.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "tailwind-merge": "^3.6.0",
    "uuidv7": "^1.2.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^20",
    "@types/pg": "^8.20.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "drizzle-kit": "^0.31.10",
    "eslint": "^9",
    "eslint-config-next": "16.2.6",
    "tailwindcss": "^4",
    "tsx": "^4.22.3",
    "typescript": "^5",
    "vitest": "^4.1.7"
  }
}
