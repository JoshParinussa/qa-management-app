{
  "name": "qa-management-app",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "node --env-file=.env.local scripts/run-with-resolved-database.mjs next dev",
    "dev:prod": "node --env-file=.env.prod scripts/run-with-resolved-database.mjs next dev",
    "build": "node --env-file=.env.local scripts/run-with-resolved-database.mjs next build",
    "build:prod": "node --env-file=.env.prod scripts/run-with-resolved-database.mjs next build",
    "start": "node --env-file=.env.local scripts/run-with-resolved-database.mjs next start",
    "start:prod": "node --env-file=.env.prod scripts/run-with-resolved-database.mjs next start",
    "lint": "eslint",
    "test": "vitest run",
    "e2e": "playwright test",
    "typecheck": "tsc --noEmit",
    "db:generate": "node --env-file=.env.local scripts/run-with-resolved-database.mjs drizzle-kit generate",
    "db:migrate": "node --env-file=.env.local scripts/run-with-resolved-database.mjs drizzle-kit migrate",
    "db:migrate:prod": "node --env-file=.env.prod scripts/run-with-resolved-database.mjs drizzle-kit migrate",
    "db:push": "node --env-file=.env.local scripts/run-with-resolved-database.mjs drizzle-kit push",
    "db:push:prod": "node --env-file=.env.prod scripts/run-with-resolved-database.mjs drizzle-kit push",
    "db:studio": "node --env-file=.env.local scripts/run-with-resolved-database.mjs drizzle-kit studio --host 127.0.0.1 --port 4983",
    "db:studio:prod": "node --env-file=.env.prod scripts/run-with-resolved-database.mjs drizzle-kit studio --host 127.0.0.1 --port 4983",
    "db:studio:stop": "lsof -tiTCP:4983 -sTCP:LISTEN | xargs -r kill",
    "db:seed": "node --env-file=.env.local scripts/run-with-resolved-database.mjs tsx src/db/seed.ts",
    "db:seed:demo": "node --env-file=.env.local scripts/run-with-resolved-database.mjs tsx scripts/seed-local-demo.ts",
    "db:seed:weekly": "node --env-file=.env.local scripts/run-with-resolved-database.mjs tsx scripts/seed-weekly-reports.ts",
    "db:seed:prod": "node --env-file=.env.prod scripts/run-with-resolved-database.mjs tsx src/db/seed.ts",
    "db:clean-admin": "node --env-file=.env.local scripts/run-with-resolved-database.mjs tsx src/db/clean-and-seed-admin.ts",
    "db:clean-admin:prod": "node --env-file=.env.prod scripts/run-with-resolved-database.mjs tsx src/db/clean-and-seed-admin.ts",
    "db:resolve": "node --env-file=.env.local scripts/run-with-resolved-database.mjs node -e \"console.log(process.env.DATABASE_URL)\"",
    "db:resolve:prod": "node --env-file=.env.prod scripts/run-with-resolved-database.mjs node -e \"console.log(process.env.DATABASE_URL)\"",
    "users:create-qa-members": "node --env-file=.env.local scripts/run-with-resolved-database.mjs tsx scripts/create-qa-members.ts",
    "users:create-qa-members:prod": "node --env-file=.env.prod scripts/run-with-resolved-database.mjs tsx scripts/create-qa-members.ts",
    "users:create-qa-members:runtime": "node scripts/run-with-resolved-database.mjs tsx scripts/create-qa-members.ts",
    "db:reset:home": "node --env-file=.env.prod scripts/run-with-resolved-database.mjs tsx scripts/reset-database.ts",
    "prod:up": "docker compose --env-file .env.prod up -d --build",
    "prod:down": "docker compose --env-file .env.prod down",
    "prod:logs": "docker compose --env-file .env.prod logs -f app"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/modifiers": "^9.0.0",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@react-pdf/renderer": "^4.5.1",
    "@tabler/icons-react": "^3.44.0",
    "@tanstack/react-table": "^8.21.3",
    "bcryptjs": "^3.0.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "docx": "^9.7.1",
    "dotenv": "^17.4.2",
    "drizzle-orm": "^0.45.2",
    "lucide-react": "^1.17.0",
    "next": "16.2.6",
    "next-themes": "^0.4.6",
    "pg": "^8.21.0",
    "radix-ui": "^1.4.3",
    "react": "19.2.4",
    "react-day-picker": "^9.14.0",
    "react-dom": "19.2.4",
    "recharts": "^3.8.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0",
    "uuidv7": "^1.2.1",
    "vaul": "^1.1.2",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@tailwindcss/postcss": "^4",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^20",
    "@types/pg": "^8.20.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "drizzle-kit": "^0.31.10",
    "eslint": "^9",
    "eslint-config-next": "16.2.6",
    "tailwindcss": "^4",
    "tsx": "^4.22.3",
    "typescript": "^5",
    "vitest": "^4.1.7"
  }
}
